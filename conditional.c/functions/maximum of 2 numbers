#include <stdio.h>

int findMax(int a, int b)
{
    if(a > b)
        return a;
    else
        return b;
}

int main()
{
    int x, y, result;

    printf("Enter two numbers: ");
    scanf("%d %d", &x, &y);

    result = findMax(x, y);

    printf("Largest number = %d\n", result);

    return 0;
}